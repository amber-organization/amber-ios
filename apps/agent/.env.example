# Amber macOS Agent — environment variables
# Copy this file to .env and fill in your values.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Amber backend ──────────────────────────────────────────────────────────
AMBER_API_URL=https://api.amber.health
AMBER_AGENT_SECRET=your-secret-here          # matches AMBER_AGENT_SECRET on Railway
AMBER_USER_ID=1                              # your Amber user ID

# ── fish.audio TTS ─────────────────────────────────────────────────────────
FISH_AUDIO_API_KEY=your-fish-api-key
FISH_VOICE_ID=802e3bc2b27e49c2995d23ef70e6ac89   # Energetic Male (default)

# ── Google Calendar / Gmail ────────────────────────────────────────────────
# Run `python -m integrations.gcal_auth` and `python -m integrations.gmail_auth`
# to generate these token files via OAuth.
GCAL_TOKEN_PATH=gcal_token.json
GMAIL_TOKEN_PATH=gmail_token.json

# ── Scheduler ──────────────────────────────────────────────────────────────
AMBER_BRIEF_TIME=08:00                       # 24h local time for morning brief
AMBER_POLL_INTERVAL=15                       # seconds between task polls
