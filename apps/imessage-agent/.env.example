# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (for loading context files)
GITHUB_TOKEN=ghp_...

# Loop Message (shared sender / one per agent number)
LOOP_API_KEY=your-loop-auth-key
# LOOP_SENDER_ID is per-user (see below)

# Database (shared Postgres from services/app)
DATABASE_URL=postgres://user:pass@host:5432/amber

# User 1 — Caleb
CALEB_PHONE=+1...           # E.164 format
CALEB_LOOP_SENDER=caleb@imsg.co
CALEB_CONTEXT_REPO=calebnewtonusc/claude-context
CALEB_MESSAGES_REPO=calebnewtonusc/claude-context
CALEB_MESSAGES_FILE=LOOP_MESSAGES.md

# User 2 — Sagar
SAGAR_PHONE=+1...           # E.164 format
SAGAR_LOOP_SENDER=sagar@imsg.co
SAGAR_CONTEXT_REPO=calebnewtonusc/sagar-context
SAGAR_MESSAGES_REPO=calebnewtonusc/sagar-amber-messages
SAGAR_MESSAGES_FILE=AMBER_MESSAGES.md

# Server
PORT=3000

# Optional model override (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
