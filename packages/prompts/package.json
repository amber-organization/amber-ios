{
  "name": "@amber/prompts",
  "version": "0.1.0",
  "description": "Shared prompt templates for Amber AI features",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2"
  }
}
