{
  "name": "@amber/shared-types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for the Amber platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.2.4"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
