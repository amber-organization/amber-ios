# ── Auth ─────────────────────────────────────────────────────────────────────
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Auth0 (web + iOS) — get from Auth0 dashboard
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=https://api.amber.app   # API identifier set in Auth0 dashboard

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/amber

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Required for pgvector semantic search (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# ── Loop Message (iMessage delivery) ─────────────────────────────────────────
LOOP_API_KEY=your-loop-auth-key
LOOP_SENDER_ID=your-sender@imsg.co
LOOP_WEBHOOK_SECRET=   # REQUIRED in production — validates Loop Message webhook signatures

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # REQUIRED — get from Stripe dashboard → Webhooks
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# ── Sub-venture webhook secrets ───────────────────────────────────────────────
# Each integration sets a shared secret so only their servers can push signals
FIDUCIARYOS_WEBHOOK_SECRET=
CLEAROUT_WEBHOOK_SECRET=
MARROW_WEBHOOK_SECRET=
STORY_WEBHOOK_SECRET=
DNOB_WEBHOOK_SECRET=

# ── Agent daemon ──────────────────────────────────────────────────────────────
AMBER_AGENT_SECRET=   # REQUIRED — shared secret between macOS agent and API
APP_BASE_URL=https://amber.health

# ── Storage (GCP Cloud Storage) ───────────────────────────────────────────────
STORAGE_BUCKET=amber-prod-assets

# ── Push Notifications (APNs) ─────────────────────────────────────────────────
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.amber.app
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
APNS_SANDBOX=false   # true for development, false for production

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (e.g. staging/preview URLs).
# The production origins (amber.health, localhost) are always included.
# Example: CORS_EXTRA_ORIGINS=https://amber-staging.vercel.app,https://pr-42.amber.preview.app
CORS_EXTRA_ORIGINS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=production
